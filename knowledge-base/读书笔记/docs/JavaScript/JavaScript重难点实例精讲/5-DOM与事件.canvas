    },
    {
      "id": "7e78918d66034b38a55cafa50d94b623",
      "fromNode": "74bca3e9-9834-4b04-af5c-e342a26d274a",
      "fromSide": "right",
      "toNode": "03c2a672-0925-420a-b452-18e17244a9c6",
      "toSide": "left"
    },
    {
      "id": "fdf07b8d6a134f7ca8a0885f5349abbf",
      "fromNode": "45134cc5-a53d-457f-8a77-563b5be9bf4b",
      "fromSide": "right",
      "toNode": "b57b8989-ec62-4d6e-abcf-83076ab600f5",
      "toSide": "left"
    },
    {
